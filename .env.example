NODE_ENV=development
NEXT_PUBLIC_APP_NAME=MediIntel
NEXT_PUBLIC_API_BASE_PATH=/api/backend/v1
NEXT_PUBLIC_LOGIN_REDIRECT=/dashboard
NEXT_PRIVATE_BACKEND_ORIGIN=http://127.0.0.1:8000

POSTGRES_DB=medintel
POSTGRES_USER=medintel
POSTGRES_PASSWORD=medintel
POSTGRES_HOST=database
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://medintel:medintel@database:5432/medintel
DATABASE_CONNECT_MAX_RETRIES=30
DATABASE_CONNECT_RETRY_SECONDS=2
RUN_DB_MIGRATIONS=true
SEED_MOCK_DATA=false

JWT_SECRET_KEY=change-me-in-production
JWT_SECRET_KEY_FILE=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

BACKEND_CORS_ORIGINS=http://localhost:3000
FRONTEND_APP_URL=http://localhost:3000

OPENAI_API_KEY=
OPENAI_API_KEY_FILE=
OPENAI_MODEL=gpt-4.1
OPENAI_REQUEST_TIMEOUT_SECONDS=45
AGENT_DEGRADED_MODE_ENABLED=false

CHROMADB_PATH=./chromadb
CHROMADB_COLLECTION=medintel_knowledge
UPLOADS_PATH=./uploads
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=200

SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_PASSWORD_FILE=
SENDGRID_API_KEY=
SENDGRID_API_KEY_FILE=
EMAIL_FROM=mediintel@citycarehospital.org
