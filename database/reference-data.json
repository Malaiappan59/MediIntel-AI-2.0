  "apiDefinitions": [
    {
      "name": "Inventory API",
      "endpoint": "/inventory",
      "method": "GET",
      "authentication": "Bearer JWT",
      "description": "Returns stock levels, reorder thresholds, and expiry risk across the hospital."
    },
    {
      "name": "Supplier API",
      "endpoint": "/orders/suppliers",
      "method": "GET",
      "authentication": "Bearer JWT",
      "description": "Provides supplier performance, lead times, and dependency exposure."
    },
    {
      "name": "Forecast API",
      "endpoint": "/forecast",
      "method": "GET",
      "authentication": "Bearer JWT",
      "description": "Serves demand forecasts and shortage probabilities for planning workflows."
    },
    {
      "name": "Order API",
      "endpoint": "/orders",
      "method": "POST",
      "authentication": "Bearer JWT",
      "description": "Creates and tracks mock procurement requests and approval flows."
    },
    {
      "name": "Alert API",
      "endpoint": "/alerts",
      "method": "GET",
      "authentication": "Bearer JWT",
      "description": "Streams critical, warning, info, and resolved operational alerts."
    },
    {
      "name": "Authentication API",
      "endpoint": "/auth/login",
      "method": "POST",
      "authentication": "Public",
      "description": "Issues demo authentication tokens for the MediIntel experience."
    }
